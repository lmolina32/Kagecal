        pass

    def _dump(self, event, file):
        cal = self.calendars[self.curr_calendar]
        event = cal.get_event(int(event))
        if not event:
            print(f"No event in calendar {self.curr_calendar} with id {event}.")
        with open(file, "wb") as outfile:
            pickle.dump(event, outfile)

    def _switch(self, calendar: str):
        if calendar in self.calendars:
            self.curr_calendar = calendar
        else:
            print(f"Cannot switch to calendar {calendar} that has not been joined.")

    def _get_event_input(self) -> Event:
        """This method is unholy. Forgive me."""
        while True:
            name = input("Event name: ")
            start_str = input("Event start [mm-dd-yyyy hh:mm:ss]: ")
            try:
                dt_object = datetime.strptime(start_str, "%m-%d-%Y %H:%M:%S")
            except ValueError:
                print("Invalid format.")
                continue
            start = dt_object.timestamp()
            end_str = input("Event end [mm-dd-yyyy hh:mm:ss]: ")
            try:
                dt_object = datetime.strptime(end_str, "%m-%d-%Y %H:%M:%S")
            except ValueError:
                print("Invalid format.")
                continue
            end = dt_object.timestamp()
            description = input("Event description?: ")
            location = input("Event location?: ")
            while True:
                is_repeating = input("Does this event repeat? [y/N]: ").lower()
                if is_repeating in {"y", "yes", "n", "no", ""}:
                    break
            if is_repeating in {"y", "yes"}:
                while True:
                    repeats_every_str = input(
                        "Repeats every [mon/tue/wed/thu/fri/sat/sun, space seperated]: "
                    )
                    repeats_every = set()
                    for day in repeats_every_str.lower().split():
                        # fmt: off
                        match day: 
                            case "mon": repeats_every.add(Day.MONDAY)
                            case "tue": repeats_every.add(Day.TUESDAY)
                            case "wed": repeats_every.add(Day.WEDNESDAY)
                            case "thu": repeats_every.add(Day.THURSDAY)
                            case "fri": repeats_every.add(Day.FRIDAY)
                            case "sat": repeats_every.add(Day.SATURDAY)
                            case "sun": repeats_every.add(Day.SUNDAY)
                            case _: 
                                print("Invalid day input.")
                                repeats_every.clear()
                                break
                        # fmt: on
                    if repeats_every:
                        break
                repeats_starting_str = input("Repeats starting: [MM/DD/YYYY]")
                try:
                    dt_object = datetime.strptime(repeats_starting_str, "%m-%d-%Y")
                except ValueError:
                    print("Invalid format.")
                    continue
                repeats_starting = dt_object.timestamp()
                repeats_until_str = input("Repeats until: [MM/DD/YYYY]")
                try:
                    dt_object = datetime.strptime(repeats_until_str, "%m-%d-%Y")
                except ValueError:
                    print("Invalid format.")
                    continue
                repeats_until = dt_object.timestamp()

            event = Event(
                name,
                start,
                end,
                description or None,
                location or None,
                (
                    Repeats(repeats_every, repeats_starting, repeats_until)
                    if is_repeating
                    else None
                ),
            )

            try:
                event.validate_event()
            except ValueError as e:
                print(f"Invalid format: {e}")
                continue
            return event

    def _load_event_file(self, fp: str) -> Optional[Event]:
        try:
            with open(fp, "rb") as eventfile:
                event = pickle.load(eventfile)
            event.validate_event()
            return event
        except FileNotFoundError as e:
            print(e)
        except pickle.UnpicklingError as e:
            print(e)
        except ValueError as e:
            print(e)

        return None

    def _help(self, args):
        match len(args):
            case 0:
                print("=== Help ===")
                for _, usage in self.COMMANDS.values():
                    print(usage)
                print("Press CTRL-D to exit.\n")
            case 1:
                if args[0] in self.COMMANDS:
                    print(self.COMMANDS[args[0]].usage)
                else:
                    print(f"Unknown command: {args[0]}")
            case _:
                print("Usage: help [command]")


def main() -> int:
    app = Application()
    while True:
        try:
            line = input("kagecal> ")
            command, *args = line.split()
            app.perform(command, args)
        except KeyboardInterrupt:
            print('\nType "help" to print commands, or press CTRL-D to exit.')
            continue
        except EOFError:
            return 0


if __name__ == "__main__":
    sys.exit(main())
