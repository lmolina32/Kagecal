    def _create(self, args):
        event = None
        try:
            while args:
                arg = args.pop(0)
                if arg == "-f":
                    path = args.pop(0)
                    event = self._load_event_file(path)
                    if event:
                        break
                    else:
                        return
        except IndexError:
            print("Usage: " + self.COMMANDS["create"].usage)
            return

        if not self.curr_calendar:
            print("Cannot create an event before first joining a calendar.")
            return

        if not event:
            try:
                event = self._get_event_input()
            except KeyboardInterrupt:
                print("\nCancelled.")
                return

        cal = self.calendars[self.curr_calendar]
        cal.create(*astuple(event))

