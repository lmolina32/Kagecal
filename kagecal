Command = namedtuple("Command", ["method", "usage"])


class Application:

    def __init__(self):
        # fmt: off
        self.COMMANDS: dict[str, Command] = {
            "join":   Command(self._join,   "join    calendar     Join a calendar with the given calendar name."),
            "list":   Command(self._list,   "list                 List all events in the calendar."),
            "create": Command(self._create, "create               Interactively create a new calendar event."),
            "remove": Command(self._remove, "remove  event        Delete a calendar event with a given id."),
            "modify": Command(self._modify, "modify  event        Interactively modify a calendar event with a given id."),
            "show":   Command(self._show,   "show    event        Display details of event with a given id."),
            "dump":   Command(self._dump,   "dump    event file   Write an event with a given id to a file."),
            "switch": Command(self._create, "switch  calendar     Switch the currently active calendar."),
        }
        # fmt: on

        # In the actual implementation, we would have a dicionary of Peers that each manage one calendar.
        self.calendars: dict[str, Calendar] = {}
        # self.calendars: dict[str, Peer] = {}
        self.curr_calendar: Optional[Calendar] = None

        # TODO: Maybe the application should attempt to rejoin calendars

    def perform(self, command: str, args: Optional[list[str]]):
        if (
            command in {"join", "remove", "modify", "show", "switch"}
            and (args is None or len(args) != 1)
        ) or (command == "dump" and (args is None or len(args) != 2)):
            print("Usage: " + self.COMMANDS[command].usage)
            return

        # fmt: off
        match command:
            case "help" | "?":  self._help(args)
            case "join":        self._local_join(*args) #self._join(*args)
            case "list":        self._list()
            case "create":      self._create(args)
            case "remove":      self._remove(*args)
            case "modify":      self._modify(*args)
            case "show":        self._show(*args)
            case "dump":        self._dump(*args)
            case "switch":      self._switch(*args)
            case _:             print(f"Unknown command: {command}")
        # fmt: on

